{% extends 'layout.html.twig' %}

{% block title %}{{ profileUser.fullName }} - Profile{% endblock %}

{% block stylesheets %}
<style>
:root {
    --profile-primary: #10b981;
    --profile-accent: #059669;
    --profile-dark: #1f2937;
    --profile-light: #f9fafb;
}

.profile-container {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: linear-gradient(135deg, #f9fafb 0%, #ffffff 50%, #f3f4f6 100%);
    min-height: 100vh;
}


.section-title {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -0.02em;
    color: #1f2937;
    position: relative;
    display: inline-block;
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 60%;
    height: 3px;
    background: linear-gradient(90deg, var(--profile-primary), transparent);
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(16, 185, 129, 0.1);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--profile-primary), var(--profile-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.stat-card:hover::before {
    transform: scaleX(1);
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(16, 185, 129, 0.15);
}

.stat-number {
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--profile-primary), var(--profile-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.stat-number.text-red-600 {
    background: linear-gradient(135deg, #dc2626, #b91c1c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.stat-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6b7280;
    font-weight: 600;
    margin-top: 0.5rem;
}


.project-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.project-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--profile-primary), var(--profile-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.project-card:hover {
    border-color: var(--profile-primary);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.15);
    transform: translateY(-2px);
}

.project-card:hover::after {
    transform: scaleX(1);
}

.activity-item {
    padding: 1.25rem;
    background: white;
    border-radius: 12px;
    border-left: 3px solid #e5e7eb;
    transition: all 0.2s ease;
}

.activity-item:hover {
    border-left-color: var(--profile-primary);
    background: #f9fafb;
    transform: translateX(4px);
}



/* Staggered animation on load */
.fade-in-up {
    animation: fadeInUp 0.6s ease-out backwards;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.fade-in-up:nth-child(1) { animation-delay: 0.1s; }
.fade-in-up:nth-child(2) { animation-delay: 0.2s; }
.fade-in-up:nth-child(3) { animation-delay: 0.3s; }
.fade-in-up:nth-child(4) { animation-delay: 0.4s; }
</style>
{% endblock %}

{% block content %}
<div class="profile-container py-8 px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">

        {# Profile Card - Compact Design #}
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden mb-8 fade-in-up max-w-md mx-auto">
            <div class="bg-gradient-to-r from-emerald-50 via-cyan-50 to-sky-50 px-6 py-8">
                <div class="flex flex-col items-center">
                    <div class="w-32 h-32 rounded-full overflow-hidden ring-4 ring-white shadow-lg mb-4">
                        {% if profileUser.avatar %}
                            <img src="{{ app.request.basePath }}/uploads/avatars/{{ profileUser.avatar }}"
                                 alt="{{ profileUser.fullName }}"
                                 class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full bg-gradient-to-br from-emerald-400 to-cyan-500 flex items-center justify-center">
                                <span class="text-4xl font-bold text-white">{{ profileUser.initials }}</span>
                            </div>
                        {% endif %}
                    </div>

                    {# User Info #}
                    <div class="text-center">
                        <h1 class="text-2xl font-bold text-gray-900">{{ profileUser.fullName }}</h1>
                        <div class="mt-2 text-gray-600 text-sm">
                            {% if profileUser.jobTitle or profileUser.department %}
                                <span>{{ profileUser.jobTitle|default('') }}</span>
                                {% if profileUser.jobTitle and profileUser.department %}
                                    <span class="text-gray-400">·</span>
                                {% endif %}
                                <span>{{ profileUser.department|default('') }}</span>
                            {% else %}
                                <span class="text-gray-400 text-sm">No title set</span>
                            {% endif %}
                        </div>
                        <div class="mt-1 text-gray-500 text-sm">{{ profileUser.email }}</div>
                    </div>

                    {# Badges #}
                    <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
                        {% if profileUser.portalRole %}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-700">
                            {{ profileUser.portalRole.name }}
                        </span>
                        {% endif %}
                        {% if profileUser.isVerified %}
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            Verified
                        </span>
                        {% endif %}
                    </div>

                    {# Edit Button #}
                    {% if canEdit %}
                    <div class="mt-4">
                        <a href="{{ path('app_profile') }}"
                           class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition-colors text-sm font-medium shadow-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                            Edit Profile
                        </a>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Member Since #}
            <div class="px-6 py-3 bg-white border-t border-gray-100 text-center text-xs text-gray-500">
                Member since {{ profileUser.createdAt|date('F Y') }}
            </div>
        </div>

        {# Stats Grid #}
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8 fade-in-up" style="animation-delay: 0.2s;">
            <div class="stat-card">
                <div class="stat-number">{{ stats.totalProjects }}</div>
                <div class="stat-label">Projects</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">{{ stats.activeTasks }}</div>
                <div class="stat-label">Active Tasks</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">{{ stats.completedTasks }}</div>
                <div class="stat-label">Completed</div>
            </div>
            <div class="stat-card">
                <div class="stat-number {{ stats.overdueTasks > 0 ? 'text-red-600' : '' }}">{{ stats.overdueTasks }}</div>
                <div class="stat-label">Overdue</div>
            </div>
        </div>

        {# Two Column Layout #}
        <div class="grid lg:grid-cols-3 gap-8">
            {# Main Content - 2 columns #}
            <div class="lg:col-span-2 space-y-8">

                {# Projects Section #}
                {% if projects|length > 0 %}
                <div class="fade-in-up" style="animation-delay: 0.4s;">
                    <h2 class="section-title mb-6">Projects</h2>
                    <div class="grid md:grid-cols-2 gap-4">
                        {% for project in projects|slice(0, 6) %}
                        <a href="{{ path('app_project_show', {id: project.id}) }}" class="project-card">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex-1 min-w-0">
                                    <h3 class="font-semibold text-gray-900 text-lg mb-1 truncate">{{ project.name }}</h3>
                                    {% if project.description %}
                                    <p class="text-sm text-gray-600 line-clamp-2">{{ project.description }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
                                <span class="text-xs text-gray-500">
                                    {% if project.owner.id.toString == profileUser.id.toString %}
                                        <span class="text-primary-600 font-medium">Owner</span>
                                    {% else %}
                                        Member
                                    {% endif %}
                                </span>
                                <span class="text-xs text-gray-400">
                                    Updated {{ project.updatedAt|date('M d, Y') }}
                                </span>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                    {% if stats.totalProjects > 6 %}
                    <div class="text-center mt-6">
                        <span class="text-sm text-gray-500">
                            and {{ stats.totalProjects - 6 }} more project{{ stats.totalProjects - 6 > 1 ? 's' : '' }}
                        </span>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

            </div>

            {# Sidebar - 1 column #}
            <div class="space-y-8">

                {# Recent Activity #}
                {% if recentActivity|length > 0 %}
                <div class="fade-in-up" style="animation-delay: 0.5s;">
                    <h2 class="section-title mb-6">Recent Activity</h2>
                    <div class="space-y-3">
                        {% for activity in recentActivity|slice(0, 8) %}
                        <div class="activity-item">
                            <div class="text-sm text-gray-900 mb-1">{{ activity.description|raw }}</div>
                            <div class="text-xs text-gray-500">
                                {{ activity.createdAt|date('M d, Y - g:i A') }}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% else %}
                <div class="fade-in-up" style="animation-delay: 0.5s;">
                    <h2 class="section-title mb-6">Recent Activity</h2>
                    <div class="bg-gray-50 rounded-2xl p-8 text-center border-2 border-dashed border-gray-200">
                        <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-gray-500 text-sm">No recent activity</p>
                    </div>
                </div>
                {% endif %}

            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Initialize profile hover cards after page loads
document.addEventListener('DOMContentLoaded', function() {
    if (window.initProfileHoverCards) {
        window.initProfileHoverCards();
    }
});

document.addEventListener('turbo:load', function() {
    if (window.initProfileHoverCards) {
        window.initProfileHoverCards();
    }
});
</script>
{% endblock %}
